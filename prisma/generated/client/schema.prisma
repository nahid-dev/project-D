generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Donor {
  id               String    @id @default(uuid())
  phone            String    @unique
  password         String?
  fullName         String
  dob              DateTime?
  gender           String?
  bloodType        String
  city             String?
  email            String?
  healthConditions String?

  // Onboarding optional fields
  locationLat      Float?
  locationLng      Float?
  locationAddress  String?
  lastDonationDate DateTime?
  isAvailable      Boolean   @default(true)

  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PhoneOTP {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

model BloodRequest {
  id              String    @id @default(uuid())
  requesterPhone  String
  patientName     String
  bloodGroup      String
  units           Int
  locationLat     Float?
  locationLng     Float?
  locationAddress String
  hospital        String?
  contact         String
  urgency         String
  requiredDate    DateTime?
  status          String    @default("pending")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
